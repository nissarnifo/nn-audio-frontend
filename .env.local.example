# =============================================================================
# N & N Audio Systems — Local Development Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# All config is read from src/config/index.ts — only .env needs to change
# when migrating environments.
#
# ENVIRONMENT OVERVIEW:
#   Local dev  → this file (.env.local)
#   Staging    → Vercel Preview (develop branch) → staging.audiosetstest.store
#   Production → Vercel Production (main branch)  → audiosetstest.store
# =============================================================================

# ─── Backend API ─────────────────────────────────────────────────────────────
# LOCAL:      http://localhost:5000/api/v1
# STAGING:    https://api-staging.audiosetstest.store/api/v1
# PRODUCTION: https://api.audiosetstest.store/api/v1
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1

# ─── Payments (Razorpay) ─────────────────────────────────────────────────────
# LOCAL / STAGING: rzp_test_XXXXXXXXXX  (test key — always)
# PRODUCTION:      rzp_live_XXXXXXXXXX  (live key — set in Vercel dashboard only)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXX

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# LOCAL:      http://localhost:3000
# STAGING:    https://staging.audiosetstest.store
# PRODUCTION: https://audiosetstest.store
NEXTAUTH_URL=http://localhost:3000

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANT: Use a DIFFERENT secret for each environment (local, staging, production)
NEXTAUTH_SECRET=your-random-32-char-secret-here

# ─── OAuth Providers (all optional — app works without them) ──────────────────
# Leave empty to disable. Only enable providers you have set up in their portals.

# GitHub OAuth — https://github.com/settings/developers
# Callback URL: {NEXTAUTH_URL}/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Callback URL: {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Discord OAuth — https://discord.com/developers/applications
# Callback URL: {NEXTAUTH_URL}/api/auth/callback/discord
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
