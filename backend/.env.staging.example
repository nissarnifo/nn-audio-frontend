# =============================================================================
# N & N Audio Systems — Backend Staging Environment Variables
# =============================================================================
# SET THESE IN: Vercel Dashboard → Backend Project → Settings → Env Variables
#               Scope: Preview  (NOT Production)
#               Branch: develop
#
# Domain: api-staging.audiosetstest.store
#
# ⚠️  STAGING RULES:
#   - DATABASE_URL must be the Neon STAGING database — NEVER production DB
#   - Use Razorpay TEST keys (rzp_test_*)  — NEVER live keys
#   - Use a DIFFERENT JWT_SECRET than production
#   - Staging DB is safe to wipe with: npx prisma db push --force-reset
# =============================================================================

# ─── Database (Neon PostgreSQL — staging branch/database) ────────────────────
# Create a separate Neon project or database branch for staging.
# Connection string from Neon Dashboard → Connection Details → Pooled connection
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/nn_audio_staging?sslmode=require

# ─── Auth ─────────────────────────────────────────────────────────────────────
# MUST be different from production JWT_SECRET
JWT_SECRET=your-staging-jwt-secret-change-this

# ─── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://staging.audiosetstest.store

# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=staging

# ─── Cloudinary (image hosting) ───────────────────────────────────────────────
# Reuse the same Cloudinary account — staging uploads go to a different folder.
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── Payments (Razorpay) ─────────────────────────────────────────────────────
# ⚠️  MUST be test keys — rzp_test_XXXXXXXXXX
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXX
RAZORPAY_KEY_SECRET=your-razorpay-test-secret

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# Use Mailtrap in staging so real emails are never sent to real users.
EMAIL_HOST=sandbox.smtp.mailtrap.io
EMAIL_PORT=587
EMAIL_USER=your-mailtrap-username
EMAIL_PASS=your-mailtrap-password
EMAIL_FROM=staging@audiosetstest.store
ADMIN_NOTIFY_EMAIL=your-dev-email@gmail.com

# ─── Telegram notifications (optional) ───────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
