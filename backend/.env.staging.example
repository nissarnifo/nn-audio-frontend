# =============================================================================
# N & N Audio Systems — Backend Staging Environment Variables
# =============================================================================
# Used by the Render staging service (nn-audio-backend-staging).
#
# SET THESE IN: Render Dashboard → nn-audio-backend-staging → Environment
#
# ⚠️  STAGING RULES:
#   - DATABASE_URL must point to nn-audio-db-staging — NEVER production DB
#   - Use Razorpay TEST keys (rzp_test_*)  — NEVER live keys
#   - Use a DIFFERENT JWT_SECRET than production
#   - Staging DB is safe to wipe with: npx prisma db push --force-reset
# =============================================================================

# ─── Database ─────────────────────────────────────────────────────────────────
# Render auto-fills this from the nn-audio-db-staging database (render.yaml)
DATABASE_URL=postgresql://user:password@localhost:5432/nn_audio_staging

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# MUST be different from production JWT_SECRET
JWT_SECRET=your-staging-jwt-secret-change-this

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Vercel preview URL for develop branch
FRONTEND_URL=https://nn-audio-frontend-git-develop-yourteam.vercel.app

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=staging

# ─── Cloudinary (image hosting) ───────────────────────────────────────────────
# You can reuse the same Cloudinary account — staging uploads go to a separate
# folder prefix. Or create a separate Cloudinary environment for isolation.
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── Payments (Razorpay) ──────────────────────────────────────────────────────
# ⚠️  MUST be test keys in staging — rzp_test_XXXXXXXXXX / matching secret
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXX
RAZORPAY_KEY_SECRET=your-razorpay-test-secret

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# Can use a test email service like Mailtrap (https://mailtrap.io) in staging
# so real emails are never sent to real users during testing.
EMAIL_HOST=sandbox.smtp.mailtrap.io
EMAIL_PORT=587
EMAIL_USER=your-mailtrap-username
EMAIL_PASS=your-mailtrap-password
EMAIL_FROM=staging@nn-audio.test
ADMIN_NOTIFY_EMAIL=your-dev-email@gmail.com

# ─── Telegram notifications (optional) ───────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
