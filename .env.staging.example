# =============================================================================
# N & N Audio Systems — Staging Environment Variables (Frontend)
# =============================================================================
# SET THESE IN: Vercel Dashboard → Frontend Project → Settings → Env Variables
#               Scope: Preview  (NOT Production)
#               Branch: develop
#
# Domain: staging.audiosetstest.store
#
# ⚠️  STAGING RULES:
#   - Always use Razorpay TEST keys (rzp_test_*)  — NEVER live keys
#   - Always point to the staging backend (api-staging.audiosetstest.store)
#   - Always use a DIFFERENT NEXTAUTH_SECRET than production
# =============================================================================

# ─── Backend API ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api-staging.audiosetstest.store/api/v1

# ─── Payments (Razorpay) ─────────────────────────────────────────────────────
# ⚠️  MUST be a test key — use rzp_test_XXXXXXXXXX
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXX

# ─── NextAuth ─────────────────────────────────────────────────────────────────
NEXTAUTH_URL=https://staging.audiosetstest.store

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# MUST be different from production secret
NEXTAUTH_SECRET=your-staging-random-32-char-secret-here

# ─── OAuth Providers (optional) ───────────────────────────────────────────────
# Use staging callback URLs: https://staging.audiosetstest.store/api/auth/callback/<provider>

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
