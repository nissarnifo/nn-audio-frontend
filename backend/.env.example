# =============================================================================
# N & N Audio Systems — Backend Local Development Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values for local development.
#
# ENVIRONMENT OVERVIEW:
#   Local dev  → this file (.env)
#   Staging    → Vercel Dashboard → Backend Project → Preview env vars
#   Production → Vercel Dashboard → Backend Project → Production env vars
#
# Database options:
#   Local: PostgreSQL (localhost) or Neon free tier with direct connection URL
#   Staging/Production: Neon PostgreSQL (Vercel-native integration)
# =============================================================================

# ─── Database (Neon PostgreSQL) ───────────────────────────────────────────────
# LOCAL:      postgresql://user:password@localhost:5432/nn_audio
# NEON:       postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/nn_audio?sslmode=require
DATABASE_URL=postgresql://user:password@localhost:5432/nn_audio

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this

# ─── CORS ─────────────────────────────────────────────────────────────────────
# LOCAL: http://localhost:3000
FRONTEND_URL=http://localhost:3000

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Cloudinary (image hosting) ───────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── Payments (Razorpay) ─────────────────────────────────────────────────────
# LOCAL / STAGING: rzp_test_XXXXXXXXXX  — always test key locally
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-test-secret

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# LOCAL: Use Mailtrap (https://mailtrap.io) to capture emails without sending
EMAIL_HOST=sandbox.smtp.mailtrap.io
EMAIL_PORT=587
EMAIL_USER=your-mailtrap-username
EMAIL_PASS=your-mailtrap-password
EMAIL_FROM=dev@nn-audio.local
ADMIN_NOTIFY_EMAIL=your-dev-email@gmail.com

# ─── Telegram notifications (optional) ───────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
