# =============================================================================
# N & N Audio — Environment Variables
# =============================================================================
# Copy this file to .env.local for LOCAL development.
# For Vercel: add these in Project → Settings → Environment Variables
#             (set each var for "Development", "Preview", or "Production")
#
# ENVIRONMENTS:
#   Local dev  → .env.local (never commit this file)
#   Vercel dev → "Preview" environment in Vercel dashboard
#   Production → "Production" environment in Vercel dashboard
# =============================================================================

# ─── Database ─────────────────────────────────────────────────────────────────
# LOCAL DEV:  use a local PostgreSQL or free Neon dev branch
# VERCEL DEV: create a separate dev database on Neon/Supabase
# PRODUCTION: create a separate prod database on Neon/Vercel Postgres/Supabase
#
# Get a free database at: https://neon.tech  or  https://supabase.com
DATABASE_URL=postgresql://user:password@host:5432/nn_audio_dev?sslmode=require

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate JWT_SECRET:     node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Generate NEXTAUTH_SECRET: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANT: Use DIFFERENT secrets for dev and production!
JWT_SECRET=your-dev-jwt-secret-min-32-chars-change-this
NEXTAUTH_SECRET=your-dev-nextauth-secret-change-this
NEXTAUTH_URL=http://localhost:3000

# ─── Cloudinary (image uploads) ───────────────────────────────────────────────
# Get free account at: https://cloudinary.com
# Dashboard → Settings → API Keys
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── Razorpay (payments) ──────────────────────────────────────────────────────
# TEST keys for dev, LIVE keys for production
# Get keys at: https://dashboard.razorpay.com → Settings → API Keys
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXX
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXX
RAZORPAY_KEY_SECRET=your-razorpay-test-secret

# ─── Admin account (for first-time seed) ──────────────────────────────────────
ADMIN_EMAIL=admin@nnaudio.com
ADMIN_PASSWORD=change-this-strong-password

# ─── Email — password reset emails (optional) ─────────────────────────────────
# Use Gmail App Password: https://myaccount.google.com → Security → App passwords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your-gmail-app-password
EMAIL_FROM=N & N Audio <your@gmail.com>
EMAIL_TO=admin@nnaudio.com

# ─── Telegram — order notifications (optional) ────────────────────────────────
# Create bot: https://t.me/BotFather → /newbot
# Get chat ID: send a message to bot then visit:
#   https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── OAuth (optional — leave empty to disable) ────────────────────────────────
# GitHub:  https://github.com/settings/developers → OAuth Apps
#   Callback: http://localhost:3000/api/auth/callback/github (dev)
#             https://your-app.vercel.app/api/auth/callback/github (prod)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google:  https://console.cloud.google.com → APIs & Services → Credentials
#   Callback: http://localhost:3000/api/auth/callback/google (dev)
#             https://your-app.vercel.app/api/auth/callback/google (prod)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Discord: https://discord.com/developers/applications
#   Callback: http://localhost:3000/api/auth/callback/discord (dev)
#             https://your-app.vercel.app/api/auth/callback/discord (prod)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
