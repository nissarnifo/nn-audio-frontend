# =============================================================================
# N & N Audio Systems — Environment Variables (Single Vercel Deployment)
# =============================================================================
# Copy this file to .env.local and fill in your values.
# The backend API now runs as Next.js Route Handlers on the same Vercel project.
# No separate backend server needed.
# =============================================================================

# ─── Backend API ─────────────────────────────────────────────────────────────
# LOCAL:      http://localhost:3000/api/v1
# PRODUCTION: /api/v1  (same domain — Vercel handles it)
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1

# ─── Database (Vercel Postgres / Neon) ───────────────────────────────────────
# Get from: Vercel Dashboard → Storage → Create Database → Postgres
# Or from: neon.tech → Connection String
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── JWT Secret ──────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-random-64-char-secret-here

# ─── Cloudinary ──────────────────────────────────────────────────────────────
# Get from: cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── Razorpay ─────────────────────────────────────────────────────────────────
# TEST key:  rzp_test_XXXXXXXXXX  (use during development)
# LIVE key:  rzp_live_XXXXXXXXXX  (use in production)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# ─── Email Notifications (Gmail SMTP) ────────────────────────────────────────
# Use a Gmail App Password (not your regular password)
# https://support.google.com/accounts/answer/185833
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your-gmail-app-password
EMAIL_FROM=your-gmail@gmail.com
ADMIN_NOTIFY_EMAIL=your-admin-email@gmail.com

# ─── Telegram Notifications (optional) ───────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── App (Frontend) URL ───────────────────────────────────────────────────────
# Used for canonical URLs, OG tags, sitemap.
# Set this to your production domain in Vercel env vars.
# LOCAL:      http://localhost:3000
# PRODUCTION: https://audiosets.store
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Payments (Razorpay) ──────────────────────────────────────────────────────
# TEST key:  rzp_test_XXXXXXXXXX  (use during development)
# LIVE key:  rzp_live_XXXXXXXXXX  (use in production — get from Razorpay Dashboard)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXX

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# LOCAL:      http://localhost:3000
# 3-MONTH:    https://your-app.vercel.app
# OWN SERVER: https://yourdomain.com
NEXTAUTH_URL=http://localhost:3000

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANT: Use a DIFFERENT secret for each environment (dev, staging, production)
NEXTAUTH_SECRET=your-random-32-char-secret-here

# ─── OAuth Providers (all optional — app works without them) ──────────────────
# Leave empty to disable. Only enable providers you have set up in their portals.

# GitHub OAuth — https://github.com/settings/developers
# Callback URL: {NEXTAUTH_URL}/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Callback URL: {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Discord OAuth — https://discord.com/developers/applications
# Callback URL: {NEXTAUTH_URL}/api/auth/callback/discord
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
