# =============================================================================
# N & N Audio Systems — Staging Environment Variables
# =============================================================================
# Used by the Vercel Preview deployment of the `develop` branch.
#
# SET THESE IN: Vercel Dashboard → Project → Settings → Environment Variables
#               Scope: Preview  (not Production)
#
# ⚠️  STAGING RULES:
#   - Always use Razorpay TEST keys (rzp_test_*)  — NEVER live keys
#   - Always point to the staging backend URL
#   - Always use a DIFFERENT NEXTAUTH_SECRET than production
#   - Staging database is separate — safe to wipe & reseed
# =============================================================================

# ─── Backend API ─────────────────────────────────────────────────────────────
# Points to the Render staging service (nn-audio-backend-staging)
NEXT_PUBLIC_API_URL=https://nn-audio-backend-staging.onrender.com/api/v1

# ─── Payments (Razorpay) ─────────────────────────────────────────────────────
# ⚠️  MUST be a test key in staging — use rzp_test_XXXXXXXXXX
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXX

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Vercel gives the develop branch a stable preview URL — set it here.
# Example: https://nn-audio-frontend-git-develop-yourteam.vercel.app
NEXTAUTH_URL=https://nn-audio-frontend-git-develop-yourteam.vercel.app

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# MUST be different from production secret
NEXTAUTH_SECRET=your-staging-random-32-char-secret-here

# ─── OAuth Providers (optional) ───────────────────────────────────────────────
# Use separate OAuth app credentials for staging (different callback URLs).
# Staging callback: {NEXTAUTH_URL}/api/auth/callback/github (etc.)

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
