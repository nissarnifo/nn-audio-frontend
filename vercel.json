{
  "github": {
    "silent": true
  },
  "ignoreCommand": "[ \"$VERCEL_ENV\" != \"production\" ] && exit 0 || exit 1",
  "buildCommand": "npx prisma generate && next build",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "functions": {
    "src/app/api/warmup/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/v1/returns/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/v1/orders/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/v1/orders/[id]/route.ts": {
      "maxDuration": 60
    }
  }
}
