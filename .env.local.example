# =============================================================================
# N & N Audio Systems — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
#
# ENVIRONMENT OVERVIEW:
#   Local dev  → this file (.env.local)
#   Staging    → Vercel Preview env vars (develop branch) → staging.audiosetstest.store
#   Production → Vercel Production env vars (main branch)  → audiosetstest.store
# =============================================================================

# ─── Clerk (Authentication) ──────────────────────────────────────────────────
# Get from: https://dashboard.clerk.com → API Keys
# OAuth providers (Google, GitHub, etc.) are configured in the Clerk Dashboard.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=<your_clerk_publishable_key>
CLERK_SECRET_KEY=<your_clerk_secret_key>

# Clerk redirect URLs (leave as-is for default behaviour)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/auth/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/auth/register
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# ─── Backend API ─────────────────────────────────────────────────────────────
# LOCAL:      http://localhost:3000/api/v1
# STAGING:    https://staging.audiosetstest.store/api/v1  (or api-staging.audiosetstest.store/api/v1)
# PRODUCTION: /api/v1  (same domain — Vercel handles it)
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1

# ─── App URL ─────────────────────────────────────────────────────────────────
# LOCAL:      http://localhost:3000
# STAGING:    https://staging.audiosetstest.store
# PRODUCTION: https://audiosetstest.store
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Database (Neon PostgreSQL) ──────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── JWT Secret ──────────────────────────────────────────────────────────────
# Used by the backend to sign tokens. Generate a strong random secret.
JWT_SECRET=your-random-64-char-secret-here

# ─── Cloudinary ──────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── Razorpay ─────────────────────────────────────────────────────────────────
# LOCAL / STAGING: rzp_test_XXXXXXXXXX  (test key — always)
# PRODUCTION:      rzp_live_XXXXXXXXXX  (live key — set in Vercel dashboard only)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXX

# ─── Email Notifications (Gmail SMTP) ────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your-gmail-app-password
EMAIL_FROM=your-gmail@gmail.com
ADMIN_NOTIFY_EMAIL=your-admin-email@gmail.com

# ─── Telegram Notifications (optional) ───────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
