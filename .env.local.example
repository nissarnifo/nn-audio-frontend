# =============================================================================
# N & N Audio Systems — Frontend Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# All config is read from src/config/index.ts — only .env needs to change
# when migrating to a new server, domain, or database.
#
# LOOSE COUPLING MIGRATION GUIDE (after 3 months → own server):
#   1. Set NEXT_PUBLIC_API_URL to your new backend URL
#   2. Set NEXTAUTH_URL to your new domain
#   3. Generate a new NEXTAUTH_SECRET
#   4. Update Razorpay key to live key
#   5. Deploy — zero code changes needed
# =============================================================================

# ─── Backend API ─────────────────────────────────────────────────────────────
# LOCAL:      http://localhost:5000/api/v1
# 3-MONTH:    https://nn-audio-backend.onrender.com/api/v1
# OWN SERVER: https://api.yourdomain.com/api/v1
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1

# ─── App (Frontend) URL ───────────────────────────────────────────────────────
# Used for canonical URLs, OG tags, sitemap.
# Set this to your production domain in Vercel env vars.
# LOCAL:      http://localhost:3000
# PRODUCTION: https://audiosets.store
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Payments (Razorpay) ──────────────────────────────────────────────────────
# TEST key:  rzp_test_XXXXXXXXXX  (use during development)
# LIVE key:  rzp_live_XXXXXXXXXX  (use in production — get from Razorpay Dashboard)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXX

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# LOCAL:      http://localhost:3000
# 3-MONTH:    https://your-app.vercel.app
# OWN SERVER: https://yourdomain.com
NEXTAUTH_URL=http://localhost:3000

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANT: Use a DIFFERENT secret for each environment (dev, staging, production)
NEXTAUTH_SECRET=your-random-32-char-secret-here

# ─── OAuth Providers (all optional — app works without them) ──────────────────
# Leave empty to disable. Only enable providers you have set up in their portals.

# GitHub OAuth — https://github.com/settings/developers
# Callback URL: {NEXTAUTH_URL}/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Callback URL: {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Discord OAuth — https://discord.com/developers/applications
# Callback URL: {NEXTAUTH_URL}/api/auth/callback/discord
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
