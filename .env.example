# ─── Database (any PostgreSQL — Vercel Postgres, Neon, Supabase, etc.) ────────
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
# If using Vercel Postgres or Neon with connection pooling, also set:
# DIRECT_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET="change-this-to-a-random-32-char-string"
NEXTAUTH_SECRET="change-this-to-another-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# ─── Cloudinary (image uploads) ───────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ─── Razorpay (payments) ──────────────────────────────────────────────────────
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxx"
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="your-razorpay-key-secret"

# ─── Admin account (used by prisma/seed.ts) ───────────────────────────────────
ADMIN_EMAIL="admin@nnaudio.com"
ADMIN_PASSWORD="change-this-strong-password"

# ─── Email (optional — for password reset emails) ─────────────────────────────
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT="587"
EMAIL_USER="your@gmail.com"
EMAIL_PASS="your-app-password"
EMAIL_FROM="N & N Audio <your@gmail.com>"
EMAIL_TO="admin@nnaudio.com"

# ─── Telegram (optional — for order notifications) ────────────────────────────
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
TELEGRAM_CHAT_ID="your-chat-id"

# ─── OAuth (optional — uncomment to enable) ───────────────────────────────────
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET=""
# DISCORD_CLIENT_ID=""
# DISCORD_CLIENT_SECRET=""
